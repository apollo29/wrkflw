# Datenbank-Verbindung der Host-App (von api/index.php und bin/run-workflows.php genutzt)
DB_HOST=127.0.0.1
# Host-Port (Container intern bleibt 3306). 3307, um lokale MySQL/MariaDB nicht zu stoeren.
DB_PORT=3307
DB_NAME=workflow
DB_USER=workflow
DB_PASS=root

# Integrationstests (PHPUnit). Leer lassen, um die Integration-Suite zu ueberspringen.
# Beispiel fuer eine separate Test-Datenbank:
# WF_DB_DSN=mysql:host=127.0.0.1;port=3306;dbname=workflow_test;charset=utf8mb4
WF_DB_DSN=
WF_DB_USER=root
WF_DB_PASS=root
